{
    "use_normalization_json": "examples/data_downsampled/phase_1/normalization_config_b.json",
    "x_train_file": "examples/data_downsampled/phase_1/normalized_d4.csv",
    "y_train_file": "examples/data_downsampled/phase_1/normalized_d4.csv",
    "x_validation_file": "examples/data_downsampled/phase_1/normalized_d5.csv",
    "y_validation_file": "examples/data_downsampled/phase_1/normalized_d5.csv",
    "x_test_file": "examples/data_downsampled/phase_1/normalized_d6.csv",
    "y_test_file": "examples/data_downsampled/phase_1/normalized_d6.csv",

    "output_file": "examples/results/phase_1/phase_1_prophet_optimization_prediction.csv",
    "results_file": "examples/results/phase_1/phase_1_prophet_optimization_results.csv",
    "loss_plot_file": "examples/results/phase_1/phase_1_prophet_optimization_loss_plot.png",
    "model_plot_file": "examples/results/phase_1/phase_1_prophet_optimization_model_plot.png",
    "uncertainties_file": "examples/results/phase_1/phase_1_prophet_optimization_uncertanties.csv",
    "predictions_plot_file": "examples/results/phase_1/phase_1_prophet_optimization_predictions_plot.png",
    "stl_plot_file": "examples/results/phase_1/phase_1_prophet_optimization_stl_decomposition_plot.png",
    "wavelet_plot_file": "examples/results/phase_1/phase_1_prophet_optimization_wavelet_decomposition_plot.png",
    "tapper_plot_file": "examples/results/phase_1/phase_1_prophet_optimization_multi_tapper_decomposition_plot.png",
    "optimization_parameters_file": "examples/results/phase_1/phase_1_prophet_optimization_parameters.json",
    "optimization_statistics": "examples/results/phase_1/phase_1_prophet_optimization_stats.json",

    "target_column": "typical_price",
    "predictor_plugin": "prophet",
    "optimizer_plugin": "default_optimizer",
    "pipeline_plugin": "prophet_pipeline",
    "preprocessor_plugin": "stl_preprocessor",

    "memory_log_file": "examples/results/phase_1/phase_1_prophet_rss.csv",
    "memory_log_gpu": true,
    "memory_log_gc": false,
    "memory_log_flush_every": 1,
    "optimizer_resource_log_file": "examples/results/phase_1/phase_1_prophet_optimizer_resources.csv",
    "optimizer_recreate_predictor_each_eval": false,
    "optimizer_isolate_candidate_process": true,

    "use_optimizer": true,
    "optimization_resume_file": "examples/results/phase_1/phase_1_prophet_optimization_resume.json",
    "optimization_pause_on_resume": false,
    "population_size": 25,
    "n_generations": 25,
    "optimization_patience": 7,
    "hyperparameter_bounds": {
        "changepoint_prior_scale": [0.001, 0.5],
        "seasonality_prior_scale": [0.01, 10.0],
        "holidays_prior_scale": [0.01, 10.0],
        "regressors_prior_scale": [0.01, 10.0],
        "window_size": [24, 96]
    },

    "use_daily": false,
    "max_steps_train": 7300,
    "max_steps_val": 1575,
    "max_steps_test": 1575,

    "intermediate_layers": 1,
    "initial_layer_size": 64,
    "layer_size_divisor": 2,

    "learning_rate": 1e-4,
    "activation": "elu",
    "l2_reg": 1e-6,

    "kl_weight": 1e-3,
    "kl_anneal_epochs": 40,
    "early_patience": 120,
    "start_from_epoch": 15,

    "use_returns": false,
    "use_log1p_targets": true,
    "use_log1p_features": ["typical_price"],

    "mc_samples": 20,
    "plotted_horizon": 6,
    "mmd_lambda": 1e-4,

    "window_size": 64,
    "batch_size": 32,

    "plot_color_predicted": "red",
    "plot_color_true": "blue",
    "plot_color_uncertainty": "green",
    "plot_color_target": "orange",
    "uncertainty_color_alpha": 0.01,
    "plot_points": 48,

    "min_delta": 1e-8,
    "epochs": 2000,
    "use_strategy": false,
    "stl_period": 24,

    "predicted_horizons": [1, 2, 3, 4, 5, 6],

    "use_stl": false,
    "use_wavelets": false,
    "use_multi_tapper": false,
    "use_predicted_decompositions": false,
    "use_real_decompositions": false,
    "use_ideal_predictions": false,

    "positional_encoding": true,

    "encoder_conv_layers": 1,
    "encoder_base_filters": 76,
    "encoder_lstm_units": 17,
    "horizon_embedding_dim": 26,
    "horizon_attn_heads": 2,
    "horizon_attn_key_dim": 30,
    "decoder_dropout": 0.01,
    
    "prophet_params": {
        "growth": "linear",
        "seasonality_mode": "additive"
    },
    "interval_width": 0.8,
    "add_country_holidays": "US",
    "daily_seasonality": true,
    "weekly_seasonality": true,
    "yearly_seasonality": true,
    "use_regressors": true,
    "changepoint_prior_scale": 0.001,
    "seasonality_prior_scale": 0.01,
    "holidays_prior_scale": 0.01,
    "regressors_prior_scale": 0.01
}
