    "optimization_resume_file": "examples/results/phase_1/phase_1_tft_optimization_resume.json",
    "optimization_pause_on_resume": true,
    
    "target_column": "typical_price",
    "predictor_plugin": "tft",
    "optimizer_plugin": "default_optimizer",
    "pipeline_plugin": "stl_pipeline",
